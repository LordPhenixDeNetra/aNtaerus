# aNtaerus - configuration runtime de développement
# Copiez ce fichier vers `antaerus/.env`, puis adaptez les valeurs si nécessaire.
# Ne versionnez jamais le fichier `.env` réel.

# ------------------------------------------------------------
# Environnement commun
# ------------------------------------------------------------
ANTAERUS_ENV=development

# URLs internes utilisées par le gateway
ANTAERUS_WEB_URL=http://localhost:5173
ANTAERUS_BRAIN_URL=http://localhost:8000
ANTAERUS_ENGINE_URL=http://localhost:7000
ANTAERUS_ENGINE_GRPC_TARGET=localhost:7001

# ------------------------------------------------------------
# Gateway Go
# ------------------------------------------------------------
ANTAERUS_GATEWAY_PORT=8080
ANTAERUS_GATEWAY_VERSION=0.1.0
ANTAERUS_GATEWAY_REQUEST_TIMEOUT_MS=2000
ANTAERUS_GATEWAY_READ_HEADER_TIMEOUT_MS=5000
ANTAERUS_GATEWAY_SHUTDOWN_TIMEOUT_MS=10000
ANTAERUS_GATEWAY_IDLE_TIMEOUT_MS=30000
ANTAERUS_GATEWAY_WRITE_TIMEOUT_MS=30000
ANTAERUS_GATEWAY_JWT_SECRET=development-gateway-jwt-secret
ANTAERUS_GATEWAY_JWT_ISSUER=antaerus.gateway
ANTAERUS_GATEWAY_JWT_AUDIENCE=antaerus.web
ANTAERUS_GATEWAY_JWT_TOKEN_TTL_MS=3600000
ANTAERUS_GATEWAY_WS_HEARTBEAT_INTERVAL_MS=30000
ANTAERUS_GATEWAY_RATE_LIMIT_HTTP_RPS=10
ANTAERUS_GATEWAY_RATE_LIMIT_HTTP_BURST=20
ANTAERUS_GATEWAY_RATE_LIMIT_WS_CONNECT_RPS=2
ANTAERUS_GATEWAY_RATE_LIMIT_WS_CONNECT_BURST=5
ANTAERUS_GATEWAY_RATE_LIMIT_WS_MESSAGE_RPS=20
ANTAERUS_GATEWAY_RATE_LIMIT_WS_MESSAGE_BURST=40
# Optionnel pour activer TLS local
# ANTAERUS_GATEWAY_TLS_CERT_FILE=
# ANTAERUS_GATEWAY_TLS_KEY_FILE=

# ------------------------------------------------------------
# Brain Python
# ------------------------------------------------------------
ANTAERUS_BRAIN_PORT=8000
ANTAERUS_BRAIN_VERSION=0.1.0
ANTAERUS_BRAIN_API_SECRET=development-brain-secret
ANTAERUS_BRAIN_ASSISTANT_NAME=aNtaerus
ANTAERUS_BRAIN_ASSISTANT_SYSTEM_PROMPT=
ANTAERUS_BRAIN_DEFAULT_PROVIDER=ollama
ANTAERUS_BRAIN_ANTHROPIC_MODEL=anthropic/claude-3-5-sonnet-latest
ANTAERUS_BRAIN_OPENAI_MODEL=openai/gpt-4o-mini
ANTAERUS_BRAIN_MISTRAL_MODEL=mistral/mistral-large-latest
ANTAERUS_BRAIN_DEEPSEEK_MODEL=deepseek/deepseek-chat
ANTAERUS_BRAIN_OLLAMA_BASE_URL=http://localhost:11434
ANTAERUS_BRAIN_OLLAMA_MODEL=llama3.1:8b
ANTAERUS_BRAIN_LLM_TIMEOUT_SECONDS=30
ANTAERUS_BRAIN_MEMORY_DB_PATH=memory_data/antaerus_memory.db
ANTAERUS_BRAIN_MEMORY_TOPICS_DIR=memory_data/topics
ANTAERUS_BRAIN_MEMORY_DEFAULT_LIMIT=25

# Clés cloud facultatives. Laissez vides si vous utilisez Ollama localement.
ANTAERUS_ANTHROPIC_API_KEY=
ANTAERUS_OPENAI_API_KEY=
ANTAERUS_MISTRAL_API_KEY=
ANTAERUS_DEEPSEEK_API_KEY=

# ------------------------------------------------------------
# Engine Rust
# ------------------------------------------------------------
ANTAERUS_ENGINE_PORT=7000
ANTAERUS_ENGINE_GRPC_PORT=7001
ANTAERUS_ENGINE_VERSION=0.1.0
ANTAERUS_ENGINE_API_SECRET=development-engine-secret
ANTAERUS_ENGINE_AUDIO_INPUT_DEVICE=
ANTAERUS_ENGINE_AUDIO_OUTPUT_DEVICE=
ANTAERUS_ENGINE_AUDIO_INPUT_SAMPLE_RATE=
ANTAERUS_ENGINE_AUDIO_OUTPUT_SAMPLE_RATE=
ANTAERUS_ENGINE_VAD_MODEL_PATH=
ANTAERUS_ENGINE_WHISPER_MODEL_PATH=
ANTAERUS_ENGINE_PIPER_MODEL_PATH=
ANTAERUS_ENGINE_PIPER_CONFIG_PATH=
ANTAERUS_ENGINE_ESPEAK_DATA_PATH=

# ------------------------------------------------------------
# Outils de validation optionnels
# ------------------------------------------------------------
# ANTAERUS_GATEWAY_URL=http://127.0.0.1:8080
# ANTAERUS_RUN_LOCAL_BENCH=1
