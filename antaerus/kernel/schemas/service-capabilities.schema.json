{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://antaerus.local/contracts/service-capabilities.schema.json",
  "title": "ServiceCapabilities",
  "type": "object",
  "required": ["name", "version", "runtime", "capabilities"],
  "properties": {
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "runtime": {
      "type": "string",
      "enum": ["web", "go", "python", "rust"]
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
