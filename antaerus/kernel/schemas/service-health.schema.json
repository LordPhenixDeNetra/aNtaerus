{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://antaerus.local/contracts/service-health.schema.json",
  "title": "ServiceHealth",
  "type": "object",
  "required": ["name", "status", "version", "port", "url", "checkedAt"],
  "properties": {
    "name": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["healthy", "degraded", "offline"]
    },
    "version": {
      "type": "string"
    },
    "port": {
      "type": "integer"
    },
    "url": {
      "type": "string"
    },
    "checkedAt": {
      "type": "string",
      "format": "date-time"
    },
    "details": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
