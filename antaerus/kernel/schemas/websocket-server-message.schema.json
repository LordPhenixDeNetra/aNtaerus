{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://antaerus.local/contracts/websocket-server-message.schema.json",
  "title": "WebSocket Server Message",
  "type": "object",
  "required": ["type", "timestamp", "payload"],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "chat.token",
        "chat.complete",
        "voice.transcript",
        "voice.audio",
        "voice.vad_state",
        "mission.update",
        "system.alert",
        "proactive.notification",
        "health.heartbeat"
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "oneOf": [
        {
          "title": "chat.token",
          "required": ["sessionId", "token"],
          "properties": {
            "sessionId": { "type": "string" },
            "token": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "title": "chat.complete",
          "required": ["sessionId", "message"],
          "properties": {
            "sessionId": { "type": "string" },
            "message": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "title": "voice.transcript",
          "required": ["sessionId", "transcript"],
          "properties": {
            "sessionId": { "type": "string" },
            "transcript": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "title": "voice.audio",
          "required": ["sessionId", "audioBase64"],
          "properties": {
            "sessionId": { "type": "string" },
            "audioBase64": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "title": "voice.vad_state",
          "required": ["sessionId", "state"],
          "properties": {
            "sessionId": { "type": "string" },
            "state": {
              "type": "string",
              "enum": ["speaking", "silence"]
            }
          },
          "additionalProperties": false
        },
        {
          "title": "mission.update",
          "required": ["missionId", "status"],
          "properties": {
            "missionId": { "type": "string" },
            "status": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "title": "system.alert",
          "required": ["level", "message"],
          "properties": {
            "level": { "type": "string" },
            "message": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "title": "proactive.notification",
          "required": ["notificationId", "message"],
          "properties": {
            "notificationId": { "type": "string" },
            "message": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "title": "health.heartbeat",
          "required": ["services"],
          "properties": {
            "services": {
              "type": "array",
              "items": {
                "$ref": "service-health.schema.json"
              }
            }
          },
          "additionalProperties": false
        }
      ]
    }
  },
  "additionalProperties": false
}
